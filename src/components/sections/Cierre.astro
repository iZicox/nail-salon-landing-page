---
interface Props {
  eyebrow?: string;
  titulo: string;
  descripcion: string;
  ctaTexto: string;
  ctaHref: string;
  imagenSrc: string;
}

const { eyebrow, titulo, descripcion, ctaTexto, ctaHref, imagenSrc } = Astro.props;
---

<section class="relative h-[80vh] min-h-[600px] flex items-center justify-center overflow-hidden">
  <div class="absolute inset-0">
    <img 
      src={imagenSrc} 
      alt="" 
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0a] via-[#0a0a0a]/70 to-transparent"></div>
  </div>
  
  <div class="relative z-10 text-center px-4 max-w-3xl mx-auto" data-aos="fade-up">
    {eyebrow && (
      <span class="inline-block px-4 py-1.5 bg-[#C4964A]/10 text-[#C4964A] rounded-full text-sm font-medium mb-6 border border-[#C4964A]/20">
        {eyebrow}
      </span>
    )}
    
    <h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight" set:html={titulo} />
    
    <p class="mt-6 text-lg text-gray-300 max-w-xl mx-auto">
      {descripcion}
    </p>
    
    <div class="mt-10">
      <a 
        href={ctaHref}
        class="inline-flex items-center justify-center px-8 py-4 text-base font-bold transition transform bg-white text-gray-900 hover:bg-gray-100 rounded-full"
      >
        {ctaTexto}
      </a>
    </div>
    
    <div class="mt-12 flex items-center justify-center gap-8 text-sm text-gray-500">
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-[#C4964A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
        <span>Pago seguro</span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-[#C4964A]" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
        </svg>
        <span>4.9/5 estrellas</span>
      </div>
    </div>
  </div>
</section>
