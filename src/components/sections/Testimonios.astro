---
interface Props {
  eyebrow?: string;
  titulo: string;
  subtitulo?: string;
  testimonios: { texto: string; nombre: string }[];
  ctaTexto?: string;
  ctaHref?: string;
}

const { eyebrow, titulo, subtitulo, testimonios, ctaTexto, ctaHref } = Astro.props;
---

<section class="relative py-24 lg:py-32 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-[#0a0a0a] via-[#1a1a1a] to-[#0a0a0a]"></div>
  <div class="absolute inset-0 opacity-20">
    <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-[#B5726A] rounded-full blur-3xl"></div>
  </div>
  
  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16" data-aos="fade-up">
      {eyebrow && (
        <span class="inline-block px-4 py-1.5 bg-[#C4964A]/10 text-[#C4964A] rounded-full text-sm font-medium mb-6 border border-[#C4964A]/20">
          {eyebrow}
        </span>
      )}
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight" set:html={titulo} />
      {subtitulo && (
        <p class="mt-4 text-gray-400">{subtitulo}</p>
      )}
    </div>
    
    <div class="grid md:grid-cols-3 gap-8">
      {testimonios.map((item, index) => (
        <div 
          class="p-8 bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl"
          data-aos="fade-up" 
          data-aos-delay={index * 100}
        >
          <span class="text-5xl text-[#C4964A]/30 leading-none">"</span>
          <p class="mt-4 text-gray-300 leading-relaxed">
            {item.texto}
          </p>
          <div class="mt-6 flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-[#C4964A] flex items-center justify-center text-white font-medium text-sm">
              {item.nombre.split(' ').map(n => n[0]).join('')}
            </div>
            <span class="text-gray-400 font-medium">{item.nombre}</span>
          </div>
        </div>
      ))}
    </div>
    
    {ctaTexto && ctaHref && (
      <div class="text-center mt-12" data-aos="fade-up">
        <a 
          href={ctaHref}
          class="inline-flex items-center justify-center px-8 py-4 text-base font-bold transition transform bg-white text-gray-900 hover:bg-gray-100 rounded-full"
        >
          {ctaTexto}
        </a>
      </div>
    )}
  </div>
</section>
