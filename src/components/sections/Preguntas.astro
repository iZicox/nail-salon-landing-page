---
interface Props {
  eyebrow?: string;
  titulo: string;
  preguntas: { pregunta: string; respuesta: string }[];
  imagenSrc?: string;
  ctaTexto?: string;
  ctaHref?: string;
}

const { eyebrow, titulo, preguntas, imagenSrc, ctaTexto, ctaHref } = Astro.props;
---

<section class="relative py-24 lg:py-32 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-[#0a0a0a] via-[#1a1a1a] to-[#0a0a0a]"></div>
  
  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-5 gap-12 lg:gap-16">
      <div class="lg:col-span-3" data-aos="fade-up">
        {eyebrow && (
          <span class="inline-block px-4 py-1.5 bg-[#C4964A]/10 text-[#C4964A] rounded-full text-sm font-medium mb-6 border border-[#C4964A]/20">
            {eyebrow}
          </span>
        )}
        <h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight" set:html={titulo} />
        
        <div class="mt-12 space-y-0">
          {preguntas.map((item) => (
            <div class="border-b border-white/10">
              <details class="group">
                <summary class="py-5 flex items-center justify-between cursor-pointer list-none">
                  <span class="text-white font-medium pr-4">{item.pregunta}</span>
                  <span class="text-[#C4964A] text-2xl font-light transition-transform duration-300 group-open:rotate-45">+</span>
                </summary>
                <div class="pb-5">
                  <p class="text-gray-400 leading-relaxed">{item.respuesta}</p>
                </div>
              </details>
            </div>
          ))}
        </div>
      </div>
      <!--
      {imagenSrc && (
        <div class="lg:col-span-2 hidden lg:block" data-aos="fade-up" data-aos-delay="200">
          <img 
            src={imagenSrc} 
            alt="" 
            class="w-full h-auto rounded-2xl border border-white/10"
          />
        </div>
      )} -->
    </div>
    
    {ctaTexto && ctaHref && (
      <div class="text-center mt-12" data-aos="fade-up">
        <a 
          href={ctaHref}
          class="inline-flex items-center justify-center px-8 py-4 text-base font-bold transition transform bg-[#C4964A] hover:bg-[#b38a42] text-white rounded-full hover:scale-105 shadow-lg shadow-[#C4964A]/25"
        >
          {ctaTexto}
        </a>
      </div>
    )}
  </div>
</section>
