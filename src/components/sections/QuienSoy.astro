---
interface Props {
  nombre: string;
  biografia: string[];
  imagenSrc: string;
  stats?: { valor: string; label: string }[];
  ctaTexto?: string;
  ctaHref?: string;
}

const { nombre, biografia, imagenSrc, stats, ctaTexto, ctaHref } = Astro.props;
---

<section class="relative py-24 lg:py-32 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-[#0a0a0a] via-[#1a1a1a] to-[#0a0a0a]"></div>
  <div class="absolute inset-0 opacity-20">
    <div class="absolute top-1/2 left-0 w-72 h-72 bg-[#B5726A] rounded-full blur-3xl"></div>
  </div>
  
  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="relative" data-aos="fade-up">
        <div class="relative rounded-2xl overflow-hidden border border-white/10">
          <img 
            src={imagenSrc} 
            alt={nombre} 
            class="w-full h-auto object-cover"
          />
        </div>
        <div class="absolute -bottom-4 -right-4 w-32 h-32 bg-[#C4964A] rounded-full blur-2xl opacity-40"></div>
      </div>
      
      <div data-aos="fade-up" data-aos-delay="100">
        <span class="inline-block px-4 py-1.5 bg-[#C4964A]/10 text-[#C4964A] rounded-full text-sm font-medium mb-6 border border-[#C4964A]/20">
          Quién soy
        </span>
        
        <h2 class="text-4xl sm:text-5xl font-bold text-white leading-tight mb-6">
          Créeme, tus uñas<br />
          están en buenas manos
        </h2>
        
        <div class="space-y-4 text-gray-300 leading-relaxed">
          <p>
            Hola, soy <strong class="text-white">{nombre}</strong>.
          </p>
          {biografia.map((parrafo) => (
            <p set:html={parrafo} />
          ))}
        </div>
        
        {stats && stats.length > 0 && (
          <div class="mt-8 flex items-center gap-6">
            <div class="flex -space-x-3">
              {stats.slice(0, 3).map((stat, i) => (
                <div class="w-10 h-10 rounded-full bg-[#C4964A] flex items-center justify-center text-white text-xs font-bold border-2 border-[#0a0a0a]">
                  {stat.valor}
                </div>
              ))}
            </div>
            <span class="text-gray-400 text-sm">{stats[0]?.label}</span>
          </div>
        )}
        
        {ctaTexto && ctaHref && (
          <div class="mt-10">
            <a 
              href={ctaHref}
              class="inline-flex items-center justify-center px-8 py-4 text-base font-bold transition transform border-2 border-[#C4964A] text-[#C4964A] hover:bg-[#C4964A] hover:text-white rounded-full"
            >
              {ctaTexto}
            </a>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
