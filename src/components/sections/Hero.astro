---
interface Props {
  eyebrow?: string;
  titulo: string;
  descripcion?: string;
  ctaTexto?: string;
  ctaHref?: string;
  stats?: { icono: string; texto: string }[];
  imagenSrc?: string;
}

const { eyebrow, titulo, descripcion, ctaTexto, ctaHref, stats, imagenSrc } = Astro.props;
---

<section class="relative min-h-screen flex items-center overflow-hidden">
  <div class="absolute inset-0 bg-linear-to-br from-[#0a0a0a] via-[#1a1a1a] to-[#0a0a0a]"></div>
  <div class="absolute inset-0 opacity-30">
    <div class="absolute top-20 left-10 w-72 h-72 bg-gold rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 right-10 w-96 h-96 bg-rose rounded-full blur-3xl"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 md:py-6">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="text-center lg:text-left">
        {eyebrow && (
          <span class="inline-block px-4 py-1.5 bg-gold/10 text-gold rounded-full text-sm font-medium mb-6 border border-gold/20">
        {eyebrow}
          </span>
        )}
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6" set:html={titulo} />
        {descripcion && (
          <p class="text-lg sm:text-xl text-gray-400 mb-8 max-w-xl mx-auto lg:mx-0">{descripcion}</p>
        )}
        {ctaTexto && ctaHref && (
          <a href={ctaHref} class="inline-block px-8 py-4 bg-gold hover:bg-[#b38a42] text-white font-bold rounded-full text-lg transition transform hover:scale-105 shadow-lg shadow-gold/25">
            {ctaTexto}
          </a>
        )}
        {stats && stats.length > 0 && (
          <div class="mt-10 flex items-center justify-center lg:justify-start gap-6 text-sm text-gray-500">
            {stats.map((stat) => (
              <div class="flex items-center gap-2">
                <span class="text-gold">{stat.icono}</span>
                <span>{stat.texto}</span>
              </div>
            ))}
          </div>
        )}
      </div>
      {imagenSrc && (
        <div class="relative">
          <div class="relative rounded-2xl overflow-hidden shadow-2xl border border-white/10 bg-[#111] aspect-4/3 max-w-md mx-auto lg:max-w-none">
            <img src={imagenSrc} alt="Uñas semipermanente premium" class="w-full h-full object-cover object-[center_75%]">
            <div class="absolute -bottom-4 -right-4 w-24 h-24 bg-gold rounded-full blur-2xl opacity-50"></div>
          </div>
        </div>
      )}
    </div>
  </div>
</section>
